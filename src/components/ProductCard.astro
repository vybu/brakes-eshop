---
import type { Pad } from "../lib/products";
interface Props { pad: Pad }
const { pad } = Astro.props;
const priceLabel = pad.priceMax ? `From ${pad.priceFrom}` : (pad.priceFrom ?? "—");
---

<a href={`/products/${pad.slug}`} class="card">
  <div class="card-media">
    {pad.image ? (
      <img src={pad.image} alt={pad.name} loading="lazy" />
    ) : (
      <span class="card-media-placeholder">Brake pad</span>
    )}
  </div>
  <div class="card-body">
    <h3 class="card-name">{pad.name}</h3>
    <p class="card-desc">{pad.description}</p>
    <p class="card-price">{priceLabel}</p>
  </div>
</a>
