---
// Variant B — "Spec Sheet": technical, data-forward, motorsport catalog energy.
// Static design mock (not wired to catalog/cart). Numbers drawn from the real
// pricing sheet + wear-test data.
const rows = [
  { fit: "Impreza STI / Civic FK8", id: "101", mk: 600, sr: 700, tw2: 800, ferodo: 1169 },
  { fit: "Nissan GTR · Brembo", id: "106", mk: 800, sr: 900, tw2: 1000, ferodo: 1333 },
  { fit: "Audi RS3 / RS5 (front)", id: "103", mk: 700, sr: 900, tw2: 1000, ferodo: 1662 },
  { fit: "BMW M2", id: "112", mk: 700, sr: 800, tw2: 900, ferodo: 810 },
  { fit: "Yaris GR", id: "118", mk: 800, sr: 900, tw2: 1000, ferodo: 919 },
  { fit: "AP Racing R5", id: "304", mk: 700, sr: 800, tw2: 950, ferodo: 763 },
];
// Wear test (mm, lower = better). padWear = 2nd high-temp cycle; discWear = rotor wear.
const wear = [
  { name: "Competitor RSL1", pad: 0.3885, disc: 0.009, lava: false },
  { name: "Competitor MA45B", pad: 0.262, disc: 0.018, lava: false },
  { name: "LAVA SR", pad: 1.176, disc: 0.059, lava: true },
  { name: "LAVA TWe", pad: 0.0895, disc: 0.001, lava: true, best: true },
];
const maxPad = Math.max(...wear.map((w) => w.pad));
const compounds = [
  { code: "MK", use: "Fast road", temp: "20–500 °C", rival: "≈ Ferodo DS2500 / EBC Yellow" },
  { code: "SR", use: "Sport / trackday", temp: "40–600 °C", rival: "≈ EBC Bluestuff" },
  { code: "TW", use: "Trackday", temp: "60–750 °C", rival: "≈ Ferodo DS1.11 / RP-1" },
  { code: "TW/2", use: "Race", temp: "80–800 °C", rival: "≈ Ferodo DS3.12 / RP-X" },
  { code: "TWe", use: "Endurance", temp: "80–850 °C", rival: "Lowest wear in class" },
];
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>LAVA — Spec sheet (Variant B · Technical)</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;700&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet" />
  </head>
  <body>
    <div class="tag">Variant B · Spec Sheet</div>

    <header class="nav">
      <div class="brand"><img src="/brand/logo.png" alt="LAVA" /><span class="mono">/ friction systems</span></div>
      <a href="#" class="cta">Configure a set →</a>
    </header>

    <section class="hero">
      <p class="kicker mono">[ PERFORMANCE BRAKE PADS · PL ]</p>
      <h1>Ferodo &amp; EBC performance.<br /><span>Half the invoice.</span></h1>
      <p class="sub">
        LAVA builds direct-fit competition pads for 30+ calipers, in five compounds from
        fast-road to endurance. Same friction class as the big names — measured, not claimed.
      </p>
      <div class="stats">
        <div><b>30+</b><span class="mono">caliper fitments</span></div>
        <div><b>5</b><span class="mono">compounds MK→TWe</span></div>
        <div><b>~50%</b><span class="mono">vs Ferodo DS price</span></div>
        <div><b>0.001<i>mm</i></b><span class="mono">TWe disc wear</span></div>
      </div>
    </section>

    <section class="block">
      <div class="block-head"><h2>Price index</h2><span class="mono">zł / set · vs Ferodo DS2500</span></div>
      <div class="table-wrap">
        <table>
          <thead>
            <tr><th>Fitment</th><th class="mono">LAVA&nbsp;ID</th><th>MK</th><th>SR</th><th>TW/2</th><th>Ferodo DS</th><th>You save</th></tr>
          </thead>
          <tbody>
            {rows.map((r) => (
              <tr>
                <td class="fit">{r.fit}</td>
                <td class="mono id">{r.id}</td>
                <td class="price">{r.mk}</td>
                <td class="price">{r.sr}</td>
                <td class="price hot">{r.tw2}</td>
                <td class="mono rival">{r.ferodo}</td>
                <td class="save">−{Math.round((1 - r.mk / r.ferodo) * 100)}%</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <section class="block dark">
      <div class="block-head"><h2>Wear test</h2><span class="mono">mm after 2× high-temp cycles · lower = better</span></div>
      <div class="wear">
        {wear.map((w) => (
          <div class={`wrow${w.best ? " best" : ""}`}>
            <span class={`wname${w.lava ? " lava" : ""}`}>{w.name}</span>
            <div class="wbar"><span style={`width:${(w.pad / maxPad) * 100}%`}></span></div>
            <span class="wval mono">{w.pad.toFixed(3)} <em>pad</em></span>
            <span class="wval mono disc">{w.disc.toFixed(3)} <em>disc</em></span>
          </div>
        ))}
      </div>
      <p class="foot-note mono">TWe: ~4× less pad wear than a rival RSL1 compound, and it barely marks the rotor.</p>
    </section>

    <section class="block compounds">
      <div class="block-head"><h2>The compounds</h2><span class="mono">pick by heat, not by guesswork</span></div>
      <div class="cgrid">
        {compounds.map((c, i) => (
          <article class="cspec">
            <div class="cbar" style={`--h:${(i + 1) / compounds.length}`}></div>
            <h3>{c.code}</h3>
            <p class="cuse">{c.use}</p>
            <dl>
              <div><dt class="mono">temp</dt><dd class="mono">{c.temp}</dd></div>
              <div><dt class="mono">class</dt><dd>{c.rival}</dd></div>
            </dl>
          </article>
        ))}
      </div>
    </section>

    <section class="cad">
      <img src="/brand/photo-1.png" alt="CAD fitment of LAVA pad in caliper" />
      <div class="cad-copy">
        <h2 class="mono">MODELLED TO&nbsp;THE&nbsp;CALIPER</h2>
        <p>Each backing plate is drawn to the exact caliper geometry — 140.1 mm here, to the tenth of a millimetre. Drop-in fit, no rattle, no filing.</p>
      </div>
    </section>

    <footer class="foot"><img src="/brand/logo.png" alt="LAVA" /><span class="mono">LAVA friction systems · made in Poland</span></footer>

    <style>
      :root { --black:#0b0b0d; --panel:#141416; --line:#26262a; --red:#E43B1B; --orange:#EE7B2E; --amber:#F2A85E; --cream:#F9EFD5; --grad:linear-gradient(90deg,#E43B1B,#EE7B2E,#F2A85E,#F9EFD5); }
      * { box-sizing: border-box; margin: 0; }
      body { background: var(--black); color: var(--cream); font-family: "Space Grotesk", system-ui, sans-serif; }
      .mono { font-family: "IBM Plex Mono", monospace; }
      a { color: inherit; text-decoration: none; }
      h1,h2,h3 { font-weight: 700; letter-spacing: -0.01em; }
      .tag { position: fixed; bottom: 12px; left: 12px; z-index: 50; font-size: 11px; letter-spacing: .08em; background: var(--red); color:#fff; padding: 4px 10px; border-radius: 3px; opacity: .85; }

      .nav { display: flex; align-items: center; justify-content: space-between; padding: 20px 5vw; border-bottom: 1px solid var(--line); }
      .brand { display: flex; align-items: center; gap: 14px; }
      .brand img { height: 22px; }
      .brand span { color: #7d7870; font-size: 12px; }
      .cta { border: 1px solid #3a372f; padding: 9px 16px; border-radius: 4px; font-size: 13px; }
      .cta:hover { border-color: var(--orange); color: var(--orange); }

      .hero { padding: 12vh 5vw 9vh; max-width: 1100px; }
      .kicker { color: var(--orange); font-size: 12px; letter-spacing: .1em; margin-bottom: 26px; }
      h1 { font-size: clamp(38px, 6.5vw, 84px); line-height: 1.02; }
      h1 span { background: var(--grad); -webkit-background-clip: text; background-clip: text; color: transparent; }
      .sub { margin-top: 26px; max-width: 60ch; color: #b3ada1; font-size: clamp(15px,1.7vw,19px); line-height: 1.55; }
      .stats { display: grid; grid-template-columns: repeat(4,1fr); gap: 1px; margin-top: 54px; background: var(--line); border: 1px solid var(--line); border-radius: 6px; overflow: hidden; }
      .stats div { background: var(--black); padding: 22px 20px; }
      .stats b { display: block; font-size: 32px; }
      .stats b i { font-size: 15px; font-style: normal; color: var(--orange); }
      .stats span { font-size: 12px; color: #7d7870; }
      @media (max-width: 760px){ .stats { grid-template-columns: 1fr 1fr; } }

      .block { padding: 8vh 5vw; border-top: 1px solid var(--line); }
      .block.dark { background: var(--panel); }
      .block-head { display: flex; align-items: baseline; gap: 18px; margin-bottom: 34px; flex-wrap: wrap; }
      h2 { font-size: clamp(24px, 3.5vw, 40px); }
      .block-head span { color: #7d7870; font-size: 13px; }

      .table-wrap { overflow-x: auto; border: 1px solid var(--line); border-radius: 8px; }
      table { width: 100%; border-collapse: collapse; min-width: 640px; }
      th, td { text-align: right; padding: 15px 18px; border-bottom: 1px solid var(--line); font-size: 15px; }
      th { color: #7d7870; font-weight: 500; font-size: 12px; letter-spacing: .06em; text-transform: uppercase; }
      th:first-child, td:first-child { text-align: left; }
      tbody tr:last-child td { border-bottom: none; }
      td.fit { font-weight: 500; }
      td.id { color: var(--orange); }
      td.price { font-variant-numeric: tabular-nums; }
      td.price.hot { color: var(--amber); font-weight: 700; }
      td.rival { color: #6f6a60; text-decoration: line-through; }
      td.save { color: #7ee081; font-weight: 700; font-variant-numeric: tabular-nums; }
      tbody tr:hover { background: rgba(238,123,46,.05); }

      .wear { display: flex; flex-direction: column; gap: 14px; }
      .wrow { display: grid; grid-template-columns: 180px 1fr 120px 120px; gap: 18px; align-items: center; }
      .wname { font-size: 15px; color: #b3ada1; }
      .wname.lava { color: var(--cream); font-weight: 700; }
      .wbar { height: 12px; background: #232327; border-radius: 100px; overflow: hidden; }
      .wbar span { display: block; height: 100%; background: #4a4740; border-radius: 100px; }
      .wrow.best .wbar span { background: var(--grad); }
      .wrow.best .wname { color: var(--amber); }
      .wval { font-size: 13px; color: #8f8a7f; text-align: right; }
      .wval em { font-style: normal; color: #5f5a51; font-size: 11px; }
      .wval.disc { color: #6f6a60; }
      .foot-note { margin-top: 28px; color: var(--orange); font-size: 13px; }
      @media (max-width: 760px){ .wrow { grid-template-columns: 110px 1fr; } .wval { display: none; } }

      .cgrid { display: grid; grid-template-columns: repeat(5,1fr); gap: 14px; }
      .cspec { border: 1px solid var(--line); border-radius: 10px; padding: 22px 20px 26px; }
      .cbar { height: 5px; border-radius: 100px; margin-bottom: 20px; background: hsl(calc(26 - var(--h)*10), 90%, calc(48% + var(--h)*24%)); }
      .cspec h3 { font-size: 30px; }
      .cuse { color: var(--orange); font-size: 12px; letter-spacing: .08em; text-transform: uppercase; margin: 4px 0 18px; }
      dl div { display: flex; justify-content: space-between; gap: 10px; padding: 8px 0; border-top: 1px solid var(--line); font-size: 12px; }
      dt { color: #6f6a60; } dd { color: #b3ada1; text-align: right; }
      @media (max-width: 900px){ .cgrid { grid-template-columns: 1fr 1fr; } }

      .cad { display: grid; grid-template-columns: 1.2fr 1fr; gap: 50px; align-items: center; padding: 8vh 5vw; border-top: 1px solid var(--line); }
      .cad img { width: 100%; border-radius: 10px; }
      .cad-copy h2 { color: var(--amber); font-size: clamp(22px,3vw,34px); }
      .cad-copy p { margin-top: 16px; color: #b3ada1; font-size: 17px; line-height: 1.55; }
      @media (max-width: 800px){ .cad { grid-template-columns: 1fr; } }

      .foot { display: flex; align-items: center; gap: 14px; padding: 6vh 5vw; border-top: 1px solid var(--line); }
      .foot img { height: 18px; } .foot span { color: #6f6a60; font-size: 12px; }
    </style>
  </body>
</html>
