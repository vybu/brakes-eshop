---
// LAVA — "Studio" landing/shop, built to .context/DESIGN-SYSTEM.md.
// Instrument-grade motorsport engineering: matte warm-dark neutrals, one flat accent,
// the thermal gradient reserved solely for the 20-850C temperature scale. This IS the
// shop — the configurator (id="configure") is inline.
import ConfiguratorStudio from "../../components/ConfiguratorStudio.tsx";
import { COMPOUNDS, CALIPERS, FROM_PRICE } from "../../lib/lava-data";

// Full-system temperature domain for the signature scale.
const T_MIN = 20;
const T_MAX = 850;
const tPct = (v: number): number => ((v - T_MIN) / (T_MAX - T_MIN)) * 100;
const tRange = (t: string): [number, number] => {
  const n = t.replace(/[^\d–-]/g, "").split(/[–-]/).map((x) => parseInt(x, 10));
  return [n[0] ?? T_MIN, n[1] ?? T_MAX];
};

// LAVA vs the established brands — price per set (PLN), same friction class. Measured.
const compare = [
  { fit: "Impreza STI / Civic FK8", part: "LP-101", lava: 600, rival: 1169, brand: "Ferodo DS2500" },
  { fit: "Nissan GTR · Brembo", part: "LP-106", lava: 800, rival: 1333, brand: "Ferodo DS1.11" },
  { fit: "Audi RS3 / RS5", part: "LP-103", lava: 700, rival: 1662, brand: "Ferodo DS2500" },
  { fit: "BMW M2 · Front", part: "LP-112", lava: 700, rival: 1290, brand: "EBC Bluestuff" },
];

// Owner feedback — restrained, specific, engineering-toned.
const testimonials = [
  { quote: "Ran TW/2 on the M2 for a full Time Attack season. Consistent to the last lap, and the discs came back within spec.", name: "Marek K.", ctx: "BMW M2 · Time Attack" },
  { quote: "Swapped Ferodo DS2500 for LAVA MK on the Civic. Same bite, half the receipt, and my wheels finally stay clean.", name: "Ania W.", ctx: "Civic FK8 · fast road" },
  { quote: "TWe on the endurance build logged the lowest pad and disc wear we have measured. Fit was drop-in, no shims.", name: "Piotr Z.", ctx: "Cup car · endurance" },
];
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>LAVA — Competition brake pads, engineered in Poland</title>
    <link rel="icon" href="/favicon.svg" />
    <link rel="preconnect" href="https://api.fontshare.com" crossorigin />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://api.fontshare.com/v2/css?f[]=clash-display@500,600&f[]=switzer@400,500,600&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  </head>
  <body>
    <div class="devtag">Studio · Thorough</div>

    <header class="nav">
      <div class="nav-inner">
        <a href="#top" class="nav-logo" aria-label="LAVA home"><img src="/lava-logo-white.svg" alt="LAVA" /></a>
        <nav class="nav-links">
          <a href="#proof">Value</a>
          <a href="#compounds">Compounds</a>
          <a href="#owners">Owners</a>
          <a href="#engineering">Engineering</a>
          <a href="#configure" class="btn btn-secondary btn-sm">Configure</a>
        </nav>
      </div>
    </header>

    <main id="top">
      <!-- HERO -->
      <section class="hero">
        <div class="hero-copy">
          <p class="mono kicker">Competition brake pads · Made in Poland</p>
          <h1>The friction class of Ferodo. Half the invoice.</h1>
          <p class="lede">
            LAVA engineers direct-fit competition pads in five compounds, measured against
            Ferodo and EBC and sold for roughly half. Choose a compound, choose your caliper,
            see the price. No catalogue to decode.
          </p>
          <div class="hero-actions">
            <a href="#configure" class="btn btn-primary">Configure your set</a>
            <span class="mono from">from&nbsp; {FROM_PRICE}&nbsp;zł&nbsp;/&nbsp;set</span>
          </div>
        </div>
        <figure class="hero-media">
          <img src="/gen2/hero-assembly.jpg" alt="LAVA competition brake pad resting against a machined brake disc" />
          <figcaption class="mono">FIG. 01 — friction assembly · pad &amp; vented disc</figcaption>
        </figure>
      </section>

      <!-- PRICE PROOF -->
      <section id="proof" class="band proof">
        <div class="band-head">
          <p class="mono kicker">01 — Value, measured</p>
          <h2>Same friction class. Half the invoice.</h2>
          <p class="band-sub">
            Price per set in złoty, LAVA against the established brand in the same friction tier.
            The saving is the number, not the pitch.
          </p>
        </div>
        <div class="bars">
          {compare.map((r) => {
            const savePct = Math.round((1 - r.lava / r.rival) * 100);
            const w = Math.round((r.lava / r.rival) * 100);
            return (
              <div class="bar-row">
                <div class="bar-fit">
                  <span class="bar-name">{r.fit}</span>
                  <span class="mono bar-part">{r.part} · vs {r.brand}</span>
                </div>
                <div class="bar-stack">
                  <div class="bar-track">
                    <div class="bar bar-lava" style={`width:${w}%`}></div>
                    <span class="mono bar-val bar-val-lava">{r.lava} zł · LAVA</span>
                  </div>
                  <div class="bar-track">
                    <div class="bar bar-rival" style="width:100%"></div>
                    <span class="mono bar-val bar-val-rival">{r.rival} zł · {r.brand}</span>
                  </div>
                </div>
                <span class="mono bar-save">−{savePct}%</span>
              </div>
            );
          })}
        </div>
      </section>

      <!-- COMPOUNDS + TEMPERATURE SCALE -->
      <section id="compounds" class="band compounds">
        <div class="band-head">
          <p class="mono kicker">02 — Five compounds</p>
          <h2>Street to endurance, on one calibrated scale.</h2>
          <p class="band-sub">
            Every compound is defined by the temperature window it holds. The thermal scale below
            is the only place LAVA uses heat as colour — read each bracket against it.
          </p>
        </div>

        <div class="scale-legend">
          <div class="scale-bar" aria-hidden="true"></div>
          <div class="scale-ticks mono">
            <span>20</span><span>200</span><span>400</span><span>600</span><span>850&#8201;°C</span>
          </div>
        </div>

        <div class="c-grid">
          {COMPOUNDS.map((c, i) => {
            const [lo, hi] = tRange(c.temp);
            return (
              <article class="c-card">
                <header class="c-top">
                  <h3>{c.code}</h3>
                  <span class="mono c-idx">0{i + 1}/05</span>
                </header>
                <p class="c-use mono">{c.name}</p>
                <div class="c-window" title={c.temp}>
                  <div class="c-window-fill" style={`left:${tPct(lo)}%;width:${tPct(hi) - tPct(lo)}%`}></div>
                </div>
                <p class="mono c-temp">{c.temp}</p>
                <p class="c-note">{c.note}</p>
                <p class="mono c-rival">{c.rival}</p>
              </article>
            );
          })}
        </div>
      </section>

      <!-- CONFIGURATOR — this is the shop -->
      <section id="configure" class="band configure">
        <div class="cfg-copy">
          <p class="mono kicker">03 — Build &amp; buy</p>
          <h2>Configure your set.</h2>
          <p class="band-sub">
            No SKU matrix to search. Pick a compound, pick your caliper — the price you see is the
            set that ships. Two fittings can share a LAVA part number; one pad fits several cars.
          </p>
          <figure class="cfg-fig">
            <img src="/gen2/pad-detail.jpg" alt="Single LAVA competition brake pad, matte finish" />
            <figcaption class="mono">FIG. 02 — sintered compound · chamfered backing plate</figcaption>
          </figure>
        </div>
        <ConfiguratorStudio client:load heading="Configure your LAVA set" />
      </section>

      <!-- PRECISION / ENGINEERING -->
      <section id="engineering" class="band eng">
        <figure class="eng-media">
          <img src="/gen2/caliper.jpg" alt="Monobloc performance caliper clamped over a machined vented disc" />
          <figcaption class="mono">FIG. 03 — monobloc caliper · drilled &amp; slotted disc</figcaption>
        </figure>
        <div class="eng-copy">
          <p class="mono kicker">04 — Engineering</p>
          <h2>Modelled to the millimetre.</h2>
          <dl class="eng-list">
            <div><dt>Exact fit</dt><dd>Each backing plate is modelled to your caliper — drop-in, no filing, no rattle, no shims.</dd></div>
            <div><dt>Proven wear</dt><dd>TWe records the lowest wear in the range and marks the disc by 0.001&nbsp;mm across a session.</dd></div>
            <div><dt>Measured, not claimed</dt><dd>Every compound is placed against a named Ferodo or EBC tier — the comparison is the spec.</dd></div>
          </dl>
          <div class="dim" aria-hidden="true">
            <span class="dim-line"></span>
            <span class="mono dim-label">0.001 mm · TWe disc wear / session</span>
            <span class="dim-line"></span>
          </div>
          <a href="#configure" class="btn btn-secondary">Configure your set</a>
        </div>
      </section>

      <!-- TESTIMONIALS -->
      <section id="owners" class="band testimonials">
        <div class="band-head">
          <p class="mono kicker">05 — From the paddock</p>
          <h2>Trusted where it gets hot.</h2>
          <p class="band-sub">
            Drivers who came off the established brands and logged the difference — on the road,
            at trackdays, and through full endurance seasons.
          </p>
        </div>
        <div class="t-grid">
          {testimonials.map((t, i) => (
            <figure class="t-card">
              <span class="mono t-idx">0{i + 1}/0{testimonials.length}</span>
              <blockquote>{t.quote}</blockquote>
              <figcaption class="mono">
                <span class="t-name">{t.name}</span>
                <span class="t-ctx">{t.ctx}</span>
              </figcaption>
            </figure>
          ))}
        </div>
      </section>
    </main>

    <footer class="foot">
      <div class="foot-inner">
        <img src="/lava-logo-white.svg" alt="LAVA" class="foot-logo" />
        <div class="foot-meta mono">
          <span>LAVA · competition brake pads · made in Poland</span>
          <span>{CALIPERS.length} fitments · 5 compounds · from {FROM_PRICE} zł</span>
        </div>
      </div>
    </footer>

    <style>
      :root{
        --base:#100E0B; --surface:#17130E; --raised:#1F1A13; --raised-2:#282117;
        --hairline:#2A241B; --hairline-strong:#3A3225; --paper:#F4EDE0; --muted:#A69C88;
        --faint:#6E6656; --accent:#E5451D; --accent-hi:#F1521F; --accent-ink:#120D08;
        --thermal:linear-gradient(90deg,#E33D1B 0%,#E9682A 34%,#F1A361 66%,#FCEDCC 100%);
        --mono:"JetBrains Mono",ui-monospace,monospace;
        --text:"Switzer",system-ui,sans-serif; --display:"Clash Display","Switzer",sans-serif;
        --gutter:clamp(20px,5vw,64px); --section-y:clamp(64px,9vw,128px); --max:1280px;
        --ease:cubic-bezier(.2,0,0,1); --dur-fast:120ms; --dur:200ms; --dur-slow:320ms;
      }
      *{ box-sizing:border-box; margin:0; padding:0; }
      html{ scroll-behavior:smooth; }
      body{ background:var(--base); color:var(--paper); font-family:var(--text);
        font-size:16px; line-height:1.6; -webkit-font-smoothing:antialiased; overflow-x:hidden; }
      a{ color:inherit; text-decoration:none; }
      img{ display:block; max-width:100%; }
      .mono{ font-family:var(--mono); font-feature-settings:"tnum" 1; }

      h1,h2,h3{ font-family:var(--display); font-weight:600; letter-spacing:-.02em; }
      h1{ font-size:clamp(3.25rem,7vw,6rem); line-height:.98; max-width:16ch; }
      h2{ font-size:clamp(1.9rem,4vw,2.4375rem); line-height:1.02; letter-spacing:-.01em; max-width:20ch; }
      h3{ font-weight:500; font-size:1.25rem; letter-spacing:-.01em; }
      .kicker{ font-size:.75rem; letter-spacing:.14em; text-transform:uppercase; color:var(--faint); }

      /* dev tag */
      .devtag{ position:fixed; bottom:16px; left:16px; z-index:80; font-family:var(--mono);
        font-size:11px; letter-spacing:.04em; background:var(--raised); color:var(--muted);
        border:1px solid var(--hairline-strong); padding:5px 10px; border-radius:4px; }

      /* buttons */
      .btn{ display:inline-flex; align-items:center; justify-content:center; font-family:var(--text);
        font-weight:600; font-size:.875rem; letter-spacing:.01em; border-radius:4px; cursor:pointer;
        padding:14px 24px; transition:background var(--dur-fast) var(--ease),
        transform var(--dur-fast) var(--ease), border-color var(--dur-fast) var(--ease); }
      .btn-primary{ background:var(--accent); color:var(--accent-ink); border:1px solid var(--accent); }
      .btn-primary:hover{ background:var(--accent-hi); border-color:var(--accent-hi); transform:translateY(-1px); }
      .btn-secondary{ background:transparent; color:var(--paper); border:1px solid var(--hairline-strong); }
      .btn-secondary:hover{ border-color:var(--paper); }
      .btn-sm{ padding:9px 16px; }

      /* nav */
      .nav{ position:sticky; top:0; z-index:60; background:rgba(16,14,11,.82);
        backdrop-filter:blur(12px); border-bottom:1px solid var(--hairline); }
      .nav-inner{ max-width:var(--max); margin:0 auto; padding:14px var(--gutter);
        display:flex; align-items:center; justify-content:space-between; }
      .nav-logo img{ height:20px; }
      .nav-links{ display:flex; align-items:center; gap:28px; }
      .nav-links a:not(.btn){ color:var(--muted); font-size:.875rem; position:relative; padding:2px 0;
        transition:color var(--dur) var(--ease); }
      .nav-links a:not(.btn):hover{ color:var(--paper); }
      .nav-links a:not(.btn)::after{ content:""; position:absolute; left:0; bottom:-2px; height:1px;
        width:0; background:var(--paper); transition:width var(--dur) var(--ease); }
      .nav-links a:not(.btn):hover::after{ width:100%; }

      /* layout helpers */
      main{ display:block; }
      .band{ max-width:var(--max); margin:0 auto; padding:var(--section-y) var(--gutter);
        border-top:1px solid var(--hairline); }
      .band-head{ max-width:760px; margin-bottom:clamp(32px,5vw,56px); }
      .band-head .kicker{ display:block; margin-bottom:16px; }
      .band-sub{ margin-top:18px; color:var(--muted); font-size:1.125rem; max-width:62ch; }

      /* hero */
      .hero{ max-width:var(--max); margin:0 auto; padding:clamp(48px,7vw,96px) var(--gutter) var(--section-y);
        display:grid; grid-template-columns:7fr 5fr; gap:clamp(32px,5vw,64px); align-items:center; }
      .hero .kicker{ display:block; margin-bottom:22px; }
      .lede{ margin-top:26px; color:var(--muted); font-size:1.125rem; max-width:52ch; }
      .hero-actions{ display:flex; align-items:center; gap:24px; margin-top:34px; flex-wrap:wrap; }
      .from{ font-size:.875rem; color:var(--faint); }

      /* images — one consistent treatment */
      figure{ margin:0; }
      .hero-media img, .cfg-fig img, .eng-media img{
        width:100%; border:1px solid var(--hairline); border-radius:6px;
        filter:grayscale(.15) contrast(1.05) brightness(.92) saturate(.85); }
      figcaption{ margin-top:12px; font-size:.75rem; letter-spacing:.04em; color:var(--faint); }

      /* proof bars */
      .bars{ display:flex; flex-direction:column; }
      .bar-row{ display:grid; grid-template-columns:230px 1fr 64px; gap:24px; align-items:center;
        padding:22px 0; border-top:1px solid var(--hairline); }
      .bar-row:last-child{ border-bottom:1px solid var(--hairline); }
      .bar-name{ display:block; font-size:1rem; font-weight:500; }
      .bar-part{ display:block; font-size:.75rem; color:var(--faint); margin-top:5px; }
      .bar-stack{ display:flex; flex-direction:column; gap:8px; }
      .bar-track{ position:relative; height:28px; background:var(--surface);
        border:1px solid var(--hairline); border-radius:2px; overflow:hidden; }
      .bar{ position:absolute; inset:0 auto 0 0; height:100%; }
      .bar-lava{ background:var(--paper); }
      .bar-rival{ background:var(--hairline-strong); }
      .bar-val{ position:absolute; left:10px; top:50%; transform:translateY(-50%);
        font-size:.75rem; z-index:1; }
      .bar-val-lava{ color:var(--accent-ink); }
      .bar-val-rival{ color:var(--muted); }
      .bar-save{ font-size:1.125rem; color:var(--paper); text-align:right; }

      /* temperature scale legend (signature) */
      .scale-legend{ margin-bottom:clamp(28px,4vw,44px); }
      .scale-bar{ height:12px; border-radius:2px; background:var(--thermal); }
      .scale-ticks{ display:flex; justify-content:space-between; margin-top:8px;
        font-size:.75rem; color:var(--faint); }

      /* compounds */
      .c-grid{ display:grid; grid-template-columns:repeat(5,1fr); gap:14px; }
      .c-card{ background:var(--raised); border:1px solid var(--hairline); border-radius:4px;
        padding:22px 20px 24px; display:flex; flex-direction:column;
        transition:border-color var(--dur) var(--ease); }
      .c-card:hover{ border-color:var(--hairline-strong); }
      .c-top{ display:flex; align-items:baseline; justify-content:space-between; }
      .c-top h3{ font-size:1.9375rem; font-weight:600; }
      .c-idx{ font-size:.75rem; color:var(--faint); }
      .c-use{ font-size:.75rem; letter-spacing:.1em; text-transform:uppercase; color:var(--muted); margin:6px 0 18px; }
      .c-window{ position:relative; height:8px; border-radius:2px; background:var(--surface);
        border:1px solid var(--hairline); overflow:hidden; }
      .c-window-fill{ position:absolute; top:0; bottom:0; background:var(--paper); border-radius:2px; opacity:.85; }
      .c-temp{ font-size:.75rem; color:var(--muted); margin:10px 0 16px; }
      .c-note{ font-size:.875rem; color:var(--muted); line-height:1.5; flex:1; }
      .c-rival{ font-size:.75rem; color:var(--faint); margin-top:16px; padding-top:14px;
        border-top:1px solid var(--hairline); }

      /* configurator band */
      .configure{ display:grid; grid-template-columns:5fr 7fr; gap:clamp(32px,5vw,64px); align-items:start; }
      .cfg-copy .kicker{ display:block; margin-bottom:16px; }
      .cfg-copy h2{ margin-bottom:0; }
      .cfg-fig{ margin-top:32px; }

      /* engineering */
      .eng{ display:grid; grid-template-columns:6fr 6fr; gap:clamp(32px,5vw,64px); align-items:center; }
      .eng-copy .kicker{ display:block; margin-bottom:16px; }
      .eng-list{ display:flex; flex-direction:column; margin:28px 0 8px; }
      .eng-list div{ padding:18px 0; border-top:1px solid var(--hairline); }
      .eng-list div:last-child{ border-bottom:1px solid var(--hairline); }
      .eng-list dt{ font-weight:600; font-size:1rem; margin-bottom:6px; }
      .eng-list dd{ color:var(--muted); font-size:.9375rem; max-width:48ch; }
      .dim{ display:flex; align-items:center; gap:12px; margin:26px 0 30px; }
      .dim-line{ height:1px; background:var(--hairline-strong); flex:1; position:relative; }
      .dim-line::before,.dim-line::after{ content:""; position:absolute; top:-3px; width:1px;
        height:7px; background:var(--hairline-strong); }
      .dim-line::before{ left:0; } .dim-line::after{ right:0; }
      .dim-label{ font-size:.75rem; color:var(--faint); white-space:nowrap; }

      /* testimonials */
      .t-grid{ display:grid; grid-template-columns:repeat(3,1fr); gap:16px; }
      .t-card{ background:var(--raised); border:1px solid var(--hairline); border-radius:4px;
        padding:26px 24px 24px; display:flex; flex-direction:column; gap:20px;
        transition:border-color var(--dur) var(--ease); }
      .t-card:hover{ border-color:var(--hairline-strong); }
      .t-idx{ font-size:.75rem; letter-spacing:.06em; color:var(--faint); }
      .t-card blockquote{ font-family:var(--display); font-weight:500; font-size:1.1875rem;
        line-height:1.4; letter-spacing:-.01em; color:var(--paper); }
      .t-card figcaption{ margin-top:auto; padding-top:16px; border-top:1px solid var(--hairline);
        display:flex; flex-direction:column; gap:4px; font-size:.75rem; }
      .t-name{ color:var(--paper); }
      .t-ctx{ color:var(--faint); }

      /* footer */
      .foot{ border-top:1px solid var(--hairline); }
      .foot-inner{ max-width:var(--max); margin:0 auto; padding:48px var(--gutter);
        display:flex; align-items:center; justify-content:space-between; gap:24px; flex-wrap:wrap; }
      .foot-logo{ height:20px; }
      .foot-meta{ display:flex; flex-direction:column; gap:4px; text-align:right;
        font-size:.75rem; color:var(--faint); }

      /* responsive — collapse under 880px */
      @media (max-width:880px){
        .hero{ grid-template-columns:1fr; }
        .hero-media{ order:-1; }
        .configure,.eng{ grid-template-columns:1fr; }
        .c-grid{ grid-template-columns:repeat(2,1fr); }
        .t-grid{ grid-template-columns:1fr; }
        .bar-row{ grid-template-columns:1fr 56px; grid-template-areas:"fit save" "stack save"; }
        .bar-fit{ grid-area:fit; } .bar-stack{ grid-area:stack; } .bar-save{ grid-area:save; }
        .nav-links a:not(.btn):not([href="#configure"]){ display:none; }
        .foot-meta{ text-align:left; }
      }
      @media (max-width:520px){
        .c-grid{ grid-template-columns:1fr; }
      }
      @media (prefers-reduced-motion:reduce){
        html{ scroll-behavior:auto; }
        *{ transition:none !important; }
      }
    </style>
  </body>
</html>
