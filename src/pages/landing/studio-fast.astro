---
// Studio · Fast — LAVA rebuilt as a restrained motorsport-engineering brand.
// System: Clash Display + Satoshi + JetBrains Mono, layered warm-dark neutrals,
// ONE flat accent (#E0431D), engineering annotation motif, and the thermal
// gradient used in exactly one place: the temperature scale in the compounds section.
import ConfiguratorFast from "../../components/ConfiguratorFast.tsx";
import { COMPOUNDS, FROM_PRICE, CALIPERS } from "../../lib/lava-data";

// Price proof — LAVA set vs the equivalent-tier established brand, per set (zł).
const compare = [
  { fit: "Impreza STI / Civic FK8", pad: "LAVA-101", lava: 600, rival: 1169, brand: "Ferodo DS2500" },
  { fit: "Nissan GTR — Brembo", pad: "LAVA-106", lava: 800, rival: 1333, brand: "Ferodo DS1.11" },
  { fit: "Audi RS3 / RS5", pad: "LAVA-103", lava: 700, rival: 1662, brand: "EBC Bluestuff" },
  { fit: "BMW M2 — Front", pad: "LAVA-112", lava: 700, rival: 810, brand: "Ferodo DS2500" },
];

// Thermal scale bounds for the compounds figure (°C).
const SCALE_MIN = 20;
const SCALE_MAX = 850;
const scaleSpan = SCALE_MAX - SCALE_MIN;
const ranges: Record<string, [number, number]> = {
  "MK": [20, 500], "SR": [40, 600], "TW": [60, 750], "TW/2": [80, 800], "TWe": [80, 850],
};
const ticks = [20, 200, 400, 600, 850];
const pct = (v: number) => ((v - SCALE_MIN) / scaleSpan) * 100;

const fits = ["Impreza STI", "Civic FK8", "Lancer EVO", "Mégane RS", "Audi RS3", "Nissan GTR", "BMW M2", "Yaris GR", "Supra GR", "MX-5", "AP Racing R5", "i30N"];
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>LAVA — Competition friction, half the invoice</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preconnect" href="https://api.fontshare.com" crossorigin />
    <link href="https://api.fontshare.com/v2/css?f[]=clash-display@500,600,700&f[]=satoshi@400,500,700&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  </head>
  <body>
    <div class="devtag">Studio · Fast</div>

    <header class="nav">
      <img src="/lava-logo.svg" alt="LAVA" class="logo" />
      <nav class="nav-links">
        <a href="#proof">Proof</a>
        <a href="#compounds">Compounds</a>
        <a href="#configure">Configure</a>
        <a href="#engineering">Engineering</a>
      </nav>
      <a href="#configure" class="btn btn-sm">Build your set</a>
    </header>

    <!-- HERO -->
    <section class="hero">
      <div class="hero-copy">
        <p class="eyebrow">LAVA — PERFORMANCE FRICTION / MADE IN POLAND</p>
        <h1>Competition<br />friction.<br /><span class="accent">Half the invoice.</span></h1>
        <p class="lede">
          Direct-fit brake pads in five compounds, measured against Ferodo and EBC
          and sold for roughly half. Pick a compound, pick your caliper, see the price.
        </p>
        <div class="hero-actions">
          <a href="#configure" class="btn">Configure your set</a>
          <span class="from">from <strong>{FROM_PRICE} zł</strong> / set</span>
        </div>
      </div>

      <figure class="hero-media">
        <div class="fig">
          <img src="/gen/hero-rotor.jpg" alt="LAVA performance rotor and pad" />
        </div>
        <figcaption class="annot">
          <span class="a-tag">FIG. 00 / ROTOR + PAD</span>
          <span class="a-line">OP. CEILING — 850 °C</span>
        </figcaption>
      </figure>

      <div class="hero-specs">
        <div class="spec"><b>{CALIPERS.length}</b><span>caliper fitments</span></div>
        <div class="spec"><b>~50<i>%</i></b><span>vs Ferodo DS</span></div>
        <div class="spec"><b>850<i>°C</i></b><span>thermal ceiling</span></div>
        <div class="spec"><b>0.001<i>mm</i></b><span>TWe disc wear</span></div>
      </div>
    </section>

    <div class="ticker"><div class="ticker-track">
      {[...fits, ...fits].map((m) => <span>{m}</span>)}
    </div></div>

    <!-- PROOF -->
    <section id="proof" class="proof">
      <div class="section-head">
        <span class="fig-tag">FIG. 02 / PRICE — PER SET, PLN</span>
        <h2>The same friction class.<br />Half the invoice.</h2>
        <p>Measured against the equivalent-tier established brand, same fitment. Prices in zł, per set.</p>
      </div>

      <table class="ptable">
        <thead>
          <tr>
            <th class="c-fit">Fitment</th>
            <th class="c-pad">Part</th>
            <th class="c-num">LAVA</th>
            <th class="c-num">Established</th>
            <th class="c-save">Saving</th>
          </tr>
        </thead>
        <tbody>
          {compare.map((r) => (
            <tr>
              <td class="c-fit">{r.fit}</td>
              <td class="c-pad">{r.pad}</td>
              <td class="c-num accent">{r.lava} zł</td>
              <td class="c-num rival"><span class="rival-brand">{r.brand}</span>{r.rival} zł</td>
              <td class="c-save">−{Math.round((1 - r.lava / r.rival) * 100)}%</td>
            </tr>
          ))}
        </tbody>
      </table>
    </section>

    <!-- COMPOUNDS + TEMPERATURE SCALE -->
    <section id="compounds" class="compounds">
      <div class="section-head">
        <span class="fig-tag">FIG. 03 / COMPOUND</span>
        <h2>Five compounds.<br />Street to endurance.</h2>
        <p>One operating window each, mapped on the same thermal scale. Higher ceiling, harder stops, less fade.</p>
      </div>

      <div class="scale">
        <span class="scale-axis">°C — OPERATING RANGE</span>
        <div class="scale-bar">
          <div class="scale-grad"></div>
          {ticks.map((t) => (
            <span class="tick" style={`left:${pct(t)}%`}><i></i>{t}</span>
          ))}
        </div>
      </div>

      <div class="c-rows">
        {COMPOUNDS.map((c) => {
          const [lo, hi] = ranges[c.code];
          return (
            <article class="c-row">
              <div class="c-id">
                <div class="c-id-head">
                  <span class="c-code">{c.code}</span>
                  <span class="c-name">{c.name}</span>
                </div>
                <p class="c-note">{c.note}</p>
                <span class="c-rival">{c.rival}</span>
              </div>
              <div class="c-track">
                <div class="c-window" style={`left:${pct(lo)}%;width:${pct(hi) - pct(lo)}%`}></div>
                <span class="c-temp">{c.temp}</span>
              </div>
            </article>
          );
        })}
      </div>
    </section>

    <!-- CONFIGURATOR -->
    <section id="configure" class="configure">
      <div class="cfg-copy">
        <span class="fig-tag">FIG. 04 / BUILD</span>
        <h2>No catalog.<br />Just your set.</h2>
        <p>Choose a compound, choose your caliper. The price is instant — the same set that ships to your door from Poland.</p>
        <figure class="fig cfg-fig">
          <img src="/gen/pad-studio.jpg" alt="LAVA brake pad, studio" />
        </figure>
      </div>
      <ConfiguratorFast client:load heading="Configure your LAVA set" />
    </section>

    <!-- ENGINEERING -->
    <section id="engineering" class="eng">
      <figure class="fig eng-fig">
        <img src="/gen/caliper.jpg" alt="Performance caliper and disc" />
        <figcaption class="annot">
          <span class="a-tag">FIG. 05 / CALIPER FIT</span>
          <span class="a-line">TOL. ± 0.05 MM</span>
        </figcaption>
      </figure>
      <div class="eng-copy">
        <span class="fig-tag">FIG. 05 / PRECISION</span>
        <h2>Engineered to the millimetre.</h2>
        <dl class="specs">
          <div>
            <dt>Exact fit</dt>
            <dd>Each backing plate is modelled to your caliper. Drop-in, no filing, no rattle.</dd>
          </div>
          <div>
            <dt>Proven wear</dt>
            <dd>TWe records 0.001 mm of disc wear per stop — the lowest we make, and kind to your discs.</dd>
          </div>
          <div>
            <dt>Half the price</dt>
            <dd>Competition friction, from {FROM_PRICE} zł a set, without the competition invoice.</dd>
          </div>
        </dl>
        <a href="#configure" class="btn">Configure your set</a>
      </div>
    </section>

    <footer class="foot">
      <img src="/lava-logo.svg" alt="LAVA" class="foot-logo" />
      <div class="foot-meta">
        <span>PERFORMANCE FRICTION · MADE IN POLAND</span>
        <span>{CALIPERS.length} FITMENTS · 5 COMPOUNDS · FROM {FROM_PRICE} zł</span>
      </div>
    </footer>

    <style is:global>
      :root {
        --base:#0E0E10; --surface:#151517; --raised:#1C1C1F;
        --hairline:rgba(255,255,255,0.08); --hairline-2:rgba(255,255,255,0.16);
        --text:#ECE6DA; --muted:#8E897E; --accent:#E0431D;
        --thermal:linear-gradient(90deg,#E0431D 0%,#EE6A1F 32%,#F0902F 62%,#F2C877 86%,#F7EBCF 100%);
        --pad-x:clamp(20px,6vw,88px);
      }
      * { box-sizing:border-box; margin:0; }
      html { scroll-behavior:smooth; }
      body { background:var(--base); color:var(--text); font-family:"Satoshi",system-ui,sans-serif;
        font-size:16px; line-height:1.55; overflow-x:hidden; -webkit-font-smoothing:antialiased; }
      a { color:inherit; text-decoration:none; }

      h1,h2,h3 { font-family:"Clash Display",sans-serif; font-weight:600; line-height:1; letter-spacing:-0.02em; }
      h1 { font-size:clamp(46px,7vw,104px); font-weight:700; letter-spacing:-0.035em; }
      h2 { font-size:clamp(30px,4.4vw,56px); letter-spacing:-0.025em; }
      .accent { color:var(--accent); }
      .mono, .fig-tag, .eyebrow, .a-tag, .a-line { font-family:"JetBrains Mono",monospace; }

      /* consistent image art-direction */
      .fig { position:relative; overflow:hidden; border-radius:10px; border:1px solid var(--hairline); background:var(--surface); }
      .fig img { display:block; width:100%; height:100%; object-fit:cover;
        filter:saturate(.85) contrast(1.06) brightness(.93); }
      .fig::after { content:""; position:absolute; inset:0; pointer-events:none;
        background:linear-gradient(180deg,rgba(14,14,16,0) 40%,rgba(14,14,16,.55) 100%),
                   radial-gradient(120% 90% at 70% 20%,rgba(224,67,29,.10),transparent 60%);
        mix-blend-mode:multiply; }

      .btn { display:inline-flex; align-items:center; justify-content:center;
        background:var(--accent); color:#fff; font-weight:500; font-size:15px;
        padding:14px 24px; border-radius:4px; transition:background .18s ease, transform .18s ease; }
      .btn:hover { background:#c93916; }
      .btn:active { transform:translateY(1px); }
      .btn-sm { padding:10px 16px; font-size:13px; }

      .devtag { position:fixed; bottom:14px; left:14px; z-index:60;
        font-family:"JetBrains Mono",monospace; font-size:11px; letter-spacing:.06em;
        background:var(--raised); border:1px solid var(--hairline); color:var(--muted);
        padding:5px 11px; border-radius:4px; }

      .fig-tag { display:block; font-size:11px; letter-spacing:.16em; color:var(--muted); margin-bottom:20px; }

      /* NAV */
      .nav { display:flex; align-items:center; gap:32px; padding:22px var(--pad-x);
        border-bottom:1px solid var(--hairline); position:sticky; top:0; z-index:50;
        background:rgba(14,14,16,.82); backdrop-filter:blur(12px); }
      .logo { height:20px; }
      .nav-links { display:flex; gap:28px; margin-left:auto; font-size:14px; }
      .nav-links a { color:var(--muted); transition:color .18s ease; }
      .nav-links a:hover { color:var(--text); }

      /* HERO */
      .hero { display:grid; grid-template-columns:1.05fr .95fr; gap:clamp(32px,5vw,72px);
        align-items:end; padding:clamp(48px,8vh,104px) var(--pad-x) 0; }
      .eyebrow { font-size:12px; letter-spacing:.16em; color:var(--accent); margin-bottom:28px; }
      .lede { margin-top:28px; font-size:clamp(16px,1.6vw,19px); color:var(--muted); max-width:42ch; line-height:1.6; }
      .hero-actions { display:flex; align-items:center; gap:24px; margin-top:36px; flex-wrap:wrap; }
      .from { color:var(--muted); font-size:15px; }
      .from strong { color:var(--text); font-weight:500; }
      .hero-media { margin:0; }
      .hero-media .fig { aspect-ratio:4/3; }
      .annot { display:flex; justify-content:space-between; align-items:baseline; gap:16px; margin-top:12px; }
      .a-tag { font-size:11px; letter-spacing:.14em; color:var(--muted); }
      .a-line { font-size:11px; letter-spacing:.12em; color:var(--accent); }

      .hero-specs { grid-column:1 / -1; display:grid; grid-template-columns:repeat(4,1fr);
        gap:24px; margin-top:clamp(48px,7vh,88px); padding-top:32px; border-top:1px solid var(--hairline); }
      .spec b { display:block; font-family:"Clash Display",sans-serif; font-weight:600; font-size:clamp(30px,4vw,46px); letter-spacing:-0.02em; }
      .spec b i { font-style:normal; font-size:.42em; color:var(--muted); margin-left:2px; }
      .spec span { display:block; margin-top:6px; font-family:"JetBrains Mono",monospace; font-size:12px; color:var(--muted); }

      /* TICKER */
      .ticker { margin-top:clamp(48px,7vh,88px); border-block:1px solid var(--hairline); overflow:hidden; background:var(--surface); }
      .ticker-track { display:flex; gap:48px; padding:14px 0; width:max-content; animation:scroll 40s linear infinite; }
      .ticker-track span { font-family:"JetBrains Mono",monospace; font-size:12px; letter-spacing:.1em;
        text-transform:uppercase; color:var(--muted); }
      @keyframes scroll { to { transform:translateX(-50%); } }

      section { padding:clamp(64px,11vh,140px) var(--pad-x); }
      .section-head { max-width:640px; margin-bottom:56px; }
      .section-head p { margin-top:18px; color:var(--muted); font-size:17px; max-width:48ch; }

      /* PROOF TABLE */
      .ptable { width:100%; border-collapse:collapse; }
      .ptable th { text-align:left; font-family:"JetBrains Mono",monospace; font-weight:400;
        font-size:11px; letter-spacing:.14em; text-transform:uppercase; color:var(--muted);
        padding:0 16px 16px; border-bottom:1px solid var(--hairline-2); }
      .ptable td { padding:22px 16px; border-bottom:1px solid var(--hairline); vertical-align:baseline; }
      .ptable .c-fit { font-size:17px; font-weight:500; }
      .ptable .c-pad { font-family:"JetBrains Mono",monospace; font-size:13px; color:var(--muted); }
      .ptable .c-num { text-align:right; font-family:"JetBrains Mono",monospace; font-size:17px; white-space:nowrap; }
      .ptable td.accent { color:var(--accent); font-weight:500; }
      .ptable .rival { color:var(--muted); }
      .rival-brand { display:block; font-size:11px; letter-spacing:.06em; color:var(--muted); opacity:.7; margin-bottom:3px; text-transform:uppercase; }
      .ptable .c-save { text-align:right; font-family:"JetBrains Mono",monospace; font-size:17px; color:var(--text); white-space:nowrap; }
      .ptable th.c-num, .ptable th.c-save { text-align:right; }

      /* COMPOUNDS + SCALE */
      .scale, .c-row { display:grid; grid-template-columns:300px 1fr; gap:clamp(24px,4vw,56px); }
      .scale { align-items:center; margin-bottom:36px; }
      .scale-axis { font-family:"JetBrains Mono",monospace; font-size:11px; letter-spacing:.1em; color:var(--muted); }
      .scale-bar { position:relative; height:30px; }
      .scale-grad { position:absolute; top:0; left:0; right:0; height:8px; border-radius:3px; background:var(--thermal); }
      .tick { position:absolute; top:13px; transform:translateX(-50%); font-family:"JetBrains Mono",monospace;
        font-size:11px; color:var(--muted); white-space:nowrap; }
      .tick i { position:absolute; top:-14px; left:50%; width:1px; height:8px; background:var(--hairline-2); }

      .c-rows { display:flex; flex-direction:column; }
      .c-row { align-items:center; padding:26px 0; border-top:1px solid var(--hairline); }
      .c-row:last-child { border-bottom:1px solid var(--hairline); }
      .c-id-head { display:flex; align-items:baseline; gap:12px; }
      .c-code { font-family:"JetBrains Mono",monospace; font-size:24px; font-weight:500; letter-spacing:.02em; }
      .c-name { font-family:"Clash Display",sans-serif; font-size:15px; color:var(--text); font-weight:500; }
      .c-note { margin-top:8px; color:var(--muted); font-size:14px; line-height:1.5; max-width:34ch; }
      .c-rival { display:inline-block; margin-top:10px; font-family:"JetBrains Mono",monospace; font-size:11px; letter-spacing:.06em; color:var(--muted); }
      .c-track { position:relative; height:24px; }
      .c-track::before { content:""; position:absolute; top:8px; left:0; right:0; height:8px; border-radius:3px; background:var(--raised); }
      .c-window { position:absolute; top:8px; height:8px; border-radius:3px; background:var(--accent); }
      .c-temp { position:absolute; top:-2px; right:0; font-family:"JetBrains Mono",monospace; font-size:11px; color:var(--text); white-space:nowrap; }

      /* CONFIGURATOR */
      .configure { display:grid; grid-template-columns:1fr 1.05fr; gap:clamp(40px,5vw,80px);
        align-items:start; background:var(--surface); border-block:1px solid var(--hairline); }
      .cfg-copy h2 { font-size:clamp(28px,3.6vw,48px); }
      .cfg-copy p { margin:18px 0 32px; color:var(--muted); font-size:17px; max-width:38ch; }
      .cfg-fig { aspect-ratio:16/10; }

      /* ENGINEERING */
      .eng { display:grid; grid-template-columns:1fr 1fr; gap:clamp(40px,5vw,80px); align-items:center; }
      .eng-fig { aspect-ratio:4/5; }
      .eng-fig figcaption { position:absolute; left:14px; right:14px; bottom:14px; z-index:2; display:flex;
        justify-content:space-between; align-items:baseline; }
      .specs { display:flex; flex-direction:column; margin:28px 0 36px; }
      .specs > div { display:grid; grid-template-columns:150px 1fr; gap:24px; padding:20px 0; border-top:1px solid var(--hairline); }
      .specs > div:last-child { border-bottom:1px solid var(--hairline); }
      .specs dt { font-weight:500; font-size:16px; }
      .specs dd { color:var(--muted); font-size:15px; line-height:1.55; }

      /* FOOTER */
      .foot { display:flex; align-items:center; justify-content:space-between; gap:24px; flex-wrap:wrap;
        padding:44px var(--pad-x); border-top:1px solid var(--hairline); }
      .foot-logo { height:18px; }
      .foot-meta { display:flex; flex-direction:column; gap:6px; text-align:right; }
      .foot-meta span { font-family:"JetBrains Mono",monospace; font-size:11px; letter-spacing:.12em; color:var(--muted); }

      @media (max-width:880px){
        .hero { grid-template-columns:1fr; align-items:start; }
        .hero-media { order:-1; }
        .hero-specs { grid-template-columns:repeat(2,1fr); }
        .ptable thead { display:none; }
        .ptable, .ptable tbody, .ptable tr, .ptable td { display:block; width:100%; }
        .ptable tr { padding:20px 0; border-bottom:1px solid var(--hairline); }
        .ptable td { padding:4px 0; border:none; }
        .ptable .c-num, .ptable .c-save { text-align:left; }
        .ptable td.accent { font-size:22px; margin-top:8px; }
        .rival-brand { display:inline; margin-right:6px; }
        .scale, .c-row { grid-template-columns:1fr; gap:16px; }
        .scale-axis { display:none; }
        .configure { grid-template-columns:1fr; }
        .eng { grid-template-columns:1fr; }
        .specs > div { grid-template-columns:1fr; gap:6px; }
        .foot-meta { text-align:left; }
      }
    </style>
  </body>
</html>
