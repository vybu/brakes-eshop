---
// Chooser: all landing-page directions to compare and pick from.
const groups = [
  {
    title: "Studio-grade rebuilds",
    items: [
      { href: "/landing/studio", tag: "S1", name: "Studio · Thorough", star: true, blurb: "Documented design system, Clash Display + Switzer, retired the rainbow, and regenerated matte imagery. Instrument-grade engineering feel." },
      { href: "/landing/studio-fast", tag: "S2", name: "Studio · Fast", blurb: "Same system, faster pass: flat accent, engineering annotations, temperature-scale motif, kept the dramatic glowing hero." },
      { href: "/landing/apex", tag: "S3", name: "Apex · Vitour-matched", blurb: "Closely modelled on vitourmotorsport.eu: Montserrat, electric-blue accent, two-tone uppercase hero over a blue diagonal wedge with a floating product, image-led compound carousel, blue-underline feature tabs, a light proof + testimonial block, and a dark newsletter-style CTA over a track image. Thermal gradient kept only on the temperature bars." },
    ],
  },
  {
    title: "Refined direction (pre-studio)",
    items: [
      { href: "/landing/hybrid", tag: "D", name: "Hybrid", blurb: "A + B mixed: cinematic hero energy plus hard price/wear proof, with the pad configurator inline. Leads on “superior performance, half the price.”" },
    ],
  },
  {
    title: "Reference-inspired",
    items: [
      { href: "/landing/pod", tag: "E", name: "Pod", blurb: "Structured like eightsleep.com — premium tech, big alternating benefit sections, metric-forward." },
      { href: "/landing/arcade", tag: "F", name: "Arcade", blurb: "Structured like play.date — playful, chunky, collectible compounds, fun voice." },
      { href: "/landing/ring", tag: "G", name: "Ring", blurb: "Structured like ultrahuman.com — sleek, glossy, telemetry-style compound modes." },
    ],
  },
  {
    title: "First explorations",
    items: [
      { href: "/landing/thermal", tag: "A", name: "Thermal", blurb: "Cinematic, brand-first, huge condensed type." },
      { href: "/landing/spec", tag: "B", name: "Spec Sheet", blurb: "Technical, data-driven, price index + wear test." },
      { href: "/landing/editorial", tag: "C", name: "Editorial", blurb: "Quiet, premium, serif, lots of black space." },
    ],
  },
];
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>LAVA — Landing page variants</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
  </head>
  <body>
    <main>
      <img src="/lava-logo.svg" alt="LAVA" class="logo" />
      <h1>Pick a direction</h1>
      <p class="intro">Seven landing-page looks for LAVA. Open each, then tell me which one to build out.</p>
      {groups.map((g) => (
        <section>
          <h2>{g.title}</h2>
          <div class="grid">
            {g.items.map((v) => (
              <a class={`card${v.star ? " star" : ""}`} href={v.href}>
                <span class="badge">Variant {v.tag}{v.star ? " · recommended" : ""}</span>
                <h3>{v.name}</h3>
                <p>{v.blurb}</p>
                <span class="go">View →</span>
              </a>
            ))}
          </div>
        </section>
      ))}
    </main>
    <style>
      * { box-sizing: border-box; margin: 0; }
      body { background: #0b0b0d; color: #F9EFD5; font-family: Inter, system-ui, sans-serif; padding: 7vh 6vw 12vh; }
      main { max-width: 1120px; margin: 0 auto; }
      .logo { height: 26px; margin-bottom: 40px; }
      h1 { font-size: clamp(32px, 5vw, 52px); font-weight: 600; letter-spacing: -0.02em; }
      .intro { color: #a49e91; margin: 14px 0 40px; font-size: 18px; max-width: 48ch; }
      section { margin-top: 44px; }
      section h2 { font-size: 13px; text-transform: uppercase; letter-spacing: .1em; color: #7d7870; font-weight: 600; margin-bottom: 18px; }
      .grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 18px; }
      .card { display: flex; flex-direction: column; gap: 10px; padding: 26px 24px 22px; border: 1px solid #26262a; border-radius: 14px; text-decoration: none; color: inherit; background: #141416; transition: border-color .2s, transform .2s; }
      .card:hover { border-color: #EE7B2E; transform: translateY(-3px); }
      .card.star { border-color: #EE7B2E; background: linear-gradient(#141416,#141416) padding-box, linear-gradient(90deg,#E43B1B,#F2A85E) border-box; border: 1px solid transparent; }
      .badge { align-self: flex-start; font-size: 11px; letter-spacing: .06em; text-transform: uppercase; background: linear-gradient(90deg,#E43B1B,#F2A85E); color: #1a0d05; font-weight: 600; padding: 5px 12px; border-radius: 100px; }
      .card h3 { font-size: 24px; font-weight: 600; margin-top: 4px; }
      .card p { color: #a49e91; font-size: 14px; flex: 1; line-height: 1.5; }
      .go { color: #F2A85E; font-weight: 500; font-size: 14px; margin-top: 6px; }
      @media (max-width: 820px){ .grid { grid-template-columns: 1fr; } }
    </style>
  </body>
</html>
