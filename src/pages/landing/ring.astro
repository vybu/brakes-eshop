---
// Variant G — "Ring": Ultrahuman-inspired premium device treatment. The brake pad
// is the hero "device"; the five compounds become selectable telemetry "modes"
// with sensor-style specs. Sleek dark thermal aesthetic, tight mono data labels.
import Configurator from "../../components/Configurator.tsx";
import { COMPOUNDS, FROM_PRICE, CALIPERS } from "../../lib/lava-data";

// Telemetry-style derived specs per compound (0–100 bars for bite + wear-resistance).
// Ordered street -> endurance; kept in sync with COMPOUNDS index order.
const telemetry = [
  { bite: 62, wear: 70 },
  { bite: 74, wear: 74 },
  { bite: 85, wear: 80 },
  { bite: 94, wear: 86 },
  { bite: 90, wear: 99 },
];

// Sleek comparison — LAVA vs Ferodo / EBC, price per set (zł).
const compare = [
  { fit: "Impreza STI · Civic FK8", lava: 600, rival: 1169, rivalName: "Ferodo DS2500" },
  { fit: "Nissan GTR · Brembo", lava: 800, rival: 1333, rivalName: "Ferodo DS1.11" },
  { fit: "Audi RS3 · RS5", lava: 700, rival: 1662, rivalName: "EBC Bluestuff" },
  { fit: "BMW M2", lava: 700, rival: 810, rivalName: "Ferodo DS2500" },
];

const marquee = ["Impreza STI", "Civic FK8", "Lancer EVO", "Nissan GTR · Brembo", "Audi RS3", "BMW M2", "Yaris GR", "Supra GR", "AP Racing R5", "Mégane RS", "MX-5", "i30N", "Mustang", "Porsche"];
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>LAVA · Ring — performance brake pads, engineered in Poland (Variant G)</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Sora:wght@300;400;500;600;700&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet" />
  </head>
  <body>
    <div class="tag">Variant G · Ring</div>

    <header class="nav">
      <img src="/lava-logo.svg" alt="LAVA" class="logo" />
      <nav>
        <a href="#modes">Modes</a>
        <a href="#engineering">Engineering</a>
        <a href="#value">Value</a>
        <a href="#configure" class="cta-sm">Build</a>
      </nav>
    </header>

    <section class="hero">
      <div class="glow" aria-hidden="true"></div>
      <p class="eyebrow mono">[ PERFORMANCE BRAKE PADS · ENGINEERED IN POLAND ]</p>
      <div class="hero-device">
        <div class="hero-halo" aria-hidden="true"></div>
        <img src="/gen/pad-studio.jpg" alt="LAVA performance brake pad" />
        <span class="chip chip-tl mono">TWe · 850&deg;C ceiling</span>
        <span class="chip chip-br mono">0.001mm disc wear</span>
      </div>
      <h1>Brake harder.<br /><span>Spend&nbsp;half.</span></h1>
      <p class="lede">
        Five competition compounds. {CALIPERS.length} exact caliper fitments. Measured against
        Ferodo &amp; EBC, sold for roughly half the invoice.
      </p>
      <div class="hero-actions">
        <a href="#configure" class="btn">Configure your set</a>
        <a href="#modes" class="btn ghost">See the modes</a>
        <span class="from mono">from <strong>{FROM_PRICE} zł</strong> / set</span>
      </div>
      <div class="hero-metrics">
        <div class="hm"><b>5</b><span class="mono">compounds</span></div>
        <div class="hm"><b>{CALIPERS.length}</b><span class="mono">caliper fitments</span></div>
        <div class="hm"><b>~50<i>%</i></b><span class="mono">vs Ferodo / EBC</span></div>
        <div class="hm"><b>850<i>&deg;C</i></b><span class="mono">thermal ceiling</span></div>
      </div>
    </section>

    <div class="marquee"><div class="marquee-track">
      {[...marquee, ...marquee].map((m) => <span class="mono">{m}</span>)}
    </div></div>

    <section id="modes" class="modes">
      <div class="sec-head">
        <div>
          <p class="kicker mono">// COMPOUND MODES</p>
          <h2>Select your mode.</h2>
        </div>
        <p class="sec-note">Five compounds, one precise fit. Each tuned to a thermal window — read the telemetry, pick the mode, brake with intent.</p>
      </div>
      <div class="mode-grid">
        {COMPOUNDS.map((c, i) => (
          <article class="mode-card">
            <div class="mode-top">
              <span class="mode-idx mono">0{i + 1}</span>
              <span class="mode-dot" style={`--i:${i}`} aria-hidden="true"></span>
            </div>
            <h3>{c.code}</h3>
            <p class="mode-name">{c.name}</p>
            <p class="mode-note">{c.note}</p>
            <dl class="tele">
              <div class="tele-row">
                <dt class="mono">TEMP CEILING</dt>
                <dd class="mono">{c.temp}</dd>
              </div>
              <div class="tele-row">
                <dt class="mono">BITE</dt>
                <dd class="meter"><i style={`--v:${telemetry[i].bite}%`}></i></dd>
              </div>
              <div class="tele-row">
                <dt class="mono">WEAR RESIST</dt>
                <dd class="meter"><i style={`--v:${telemetry[i].wear}%`}></i></dd>
              </div>
              <div class="tele-row">
                <dt class="mono">RIVAL</dt>
                <dd class="mono rival">{c.rival}</dd>
              </div>
            </dl>
          </article>
        ))}
      </div>
    </section>

    <section id="engineering" class="feature">
      <div class="feature-media">
        <div class="label-tl mono">[ SENSOR · THERMAL ]</div>
        <img src="/gen/rotor-square.jpg" alt="Glowing performance rotor, top-down" />
      </div>
      <div class="feature-copy">
        <p class="kicker mono">// PRECISION ENGINEERING</p>
        <h2>Modelled to the millimetre.</h2>
        <p class="feature-lede">Every backing plate is cut to your exact caliper. Drop-in fit — no filing, no shims, no rattle. Consistent pad-to-piston contact means consistent, repeatable bite, lap after lap.</p>
        <ul class="ticks">
          <li><strong>Direct fit.</strong> {CALIPERS.length} caliper profiles, from OEM Brembo to AP Racing R5.</li>
          <li><strong>Stable friction.</strong> A high thermal ceiling holds bite through a full session.</li>
          <li><strong>Low disc wear.</strong> TWe endurance barely marks the rotor — 0.001&nbsp;mm.</li>
        </ul>
      </div>
    </section>

    <section class="feature reverse">
      <div class="feature-media">
        <div class="label-tl mono">[ FITMENT · CALIPER ]</div>
        <img src="/gen/caliper.jpg" alt="Performance caliper on wheel" />
      </div>
      <div class="feature-copy">
        <p class="kicker mono">// SPEC ANYTHING</p>
        <h2>One pad, the right car.</h2>
        <p class="feature-lede">Impreza STI, Civic FK8, Lancer EVO, Nissan GTR on Brembo, Audi RS3, BMW M2, Yaris GR, Supra GR, AP Racing R5 — the marquee fitments are covered, and the price is instant.</p>
        <div class="datastrip">
          <div><span class="mono">RANGE</span><b>Street → Race</b></div>
          <div><span class="mono">TEMP</span><b>20 – 850&deg;C</b></div>
          <div><span class="mono">ORIGIN</span><b>Poland</b></div>
        </div>
      </div>
    </section>

    <section id="value" class="value">
      <div class="sec-head">
        <div>
          <p class="kicker mono">// PRICE TELEMETRY</p>
          <h2>Same friction class.<br />Half the invoice.</h2>
        </div>
        <p class="sec-note">LAVA vs the incumbent, price per set in zł. Same performance tier — measured, not marketing.</p>
      </div>
      <div class="bars">
        {compare.map((r) => (
          <div class="bar-row">
            <span class="bar-fit">{r.fit}</span>
            <div class="bar-stack">
              <div class="bar-track">
                <div class="bar lava" style={`width:${(r.lava / r.rival) * 100}%`}></div>
                <span class="bar-tag mono">{r.lava} zł · LAVA</span>
              </div>
              <div class="bar-track">
                <div class="bar rival" style="width:100%"></div>
                <span class="bar-tag mono ghost-tag">{r.rival} zł · {r.rivalName}</span>
              </div>
            </div>
            <span class="bar-save mono">&minus;{Math.round((1 - r.lava / r.rival) * 100)}%</span>
          </div>
        ))}
      </div>
    </section>

    <section id="configure" class="configure">
      <div class="cfg-copy">
        <p class="kicker mono">// BUILD</p>
        <h2>Choose your mode. Build your set.</h2>
        <p>No catalogue to dig through. Pick a compound, pick your caliper, and the price is live — the exact set that ships to your door.</p>
        <div class="cfg-img">
          <div class="label-tl mono">[ READY TO SHIP ]</div>
          <img src="/gen/pad-studio.jpg" alt="LAVA brake pad set" />
        </div>
      </div>
      <Configurator client:load heading="Choose your compound" />
    </section>

    <footer class="foot">
      <img src="/lava-logo.svg" alt="LAVA" />
      <p class="mono">LAVA · molten performance · engineered in Poland · from {FROM_PRICE} zł / set</p>
    </footer>

    <style>
      :root {
        --black:#08080a; --panel:#121214; --line:#242428; --red:#E43B1B; --orange:#EE7B2E;
        --amber:#F2A85E; --cream:#F6F1E6; --mute:#8b877e; --dim:#5f5b53;
        --grad:linear-gradient(90deg,#E43B1B,#EE7B2E,#F2A85E,#F9EFD5);
      }
      * { box-sizing:border-box; margin:0; }
      body { background:var(--black); color:var(--cream); font-family:Sora,system-ui,sans-serif; overflow-x:hidden; -webkit-font-smoothing:antialiased; }
      .mono { font-family:"IBM Plex Mono",monospace; }
      h1,h2,h3 { font-family:Sora,sans-serif; font-weight:600; line-height:1; letter-spacing:-.02em; }
      a { color:inherit; text-decoration:none; }
      img { display:block; }
      .kicker { color:var(--orange); font-size:11px; letter-spacing:.22em; margin-bottom:14px; }

      .tag { position:fixed; bottom:12px; left:12px; z-index:60; font-size:11px; letter-spacing:.06em; background:var(--red); color:#fff; padding:5px 12px; border-radius:100px; opacity:.9; font-family:"IBM Plex Mono",monospace; }

      .nav { position:sticky; top:0; z-index:40; display:flex; align-items:center; justify-content:space-between; padding:16px 6vw; background:rgba(8,8,10,.72); backdrop-filter:blur(14px); border-bottom:1px solid var(--line); }
      .logo { height:24px; }
      .nav nav { display:flex; gap:26px; align-items:center; font-size:14px; }
      .nav nav a { color:var(--mute); transition:color .15s; }
      .nav nav a:hover { color:var(--cream); }
      .cta-sm { background:var(--grad); color:#160b04 !important; font-weight:600; padding:9px 18px; border-radius:100px; letter-spacing:.01em; }

      /* HERO — device treatment, centred, radial glow */
      .hero { position:relative; text-align:center; padding:8vh 6vw 10vh; display:flex; flex-direction:column; align-items:center; }
      .glow { position:absolute; top:-8%; left:50%; transform:translateX(-50%); width:min(1100px,120vw); height:900px; background:radial-gradient(ellipse at center, rgba(238,123,46,.16), rgba(228,59,27,.06) 38%, transparent 66%); pointer-events:none; z-index:0; }
      .hero > * { position:relative; z-index:1; }
      .eyebrow { color:var(--orange); font-size:11px; letter-spacing:.24em; margin-bottom:34px; }
      .hero-device { position:relative; width:min(420px,74vw); aspect-ratio:1/1; margin-bottom:14px; }
      .hero-halo { position:absolute; inset:-14%; border-radius:50%; background:radial-gradient(circle, rgba(238,123,46,.5), rgba(228,59,27,.18) 45%, transparent 68%); filter:blur(24px); z-index:0; }
      .hero-device img { position:relative; z-index:1; width:100%; height:100%; object-fit:cover; border-radius:26px; border:1px solid var(--line); box-shadow:0 40px 100px rgba(228,59,27,.28); }
      .chip { position:absolute; z-index:2; font-size:11px; letter-spacing:.02em; background:rgba(18,18,20,.82); border:1px solid var(--line); color:var(--amber); padding:7px 12px; border-radius:100px; backdrop-filter:blur(8px); }
      .chip-tl { top:8%; left:-6%; }
      .chip-br { bottom:8%; right:-6%; }
      h1 { font-size:clamp(46px,8vw,104px); font-weight:700; margin-top:26px; }
      h1 span { background:var(--grad); -webkit-background-clip:text; background-clip:text; color:transparent; }
      .lede { margin-top:22px; max-width:52ch; color:#c6c1b5; font-size:clamp(15px,1.7vw,19px); font-weight:300; line-height:1.5; }
      .hero-actions { display:flex; align-items:center; justify-content:center; gap:18px; margin-top:32px; flex-wrap:wrap; }
      .btn { background:var(--grad); color:#160b04; font-weight:600; padding:15px 28px; border-radius:100px; font-size:15px; transition:transform .2s, filter .2s; }
      .btn:hover { transform:translateY(-2px); filter:brightness(1.07); }
      .btn.ghost { background:transparent; color:var(--cream); border:1px solid var(--line); }
      .btn.ghost:hover { border-color:var(--amber); filter:none; }
      .from { color:var(--mute); font-size:14px; } .from strong { color:var(--cream); }
      .hero-metrics { display:grid; grid-template-columns:repeat(4,1fr); gap:1px; margin-top:56px; width:min(920px,100%); background:var(--line); border:1px solid var(--line); border-radius:16px; overflow:hidden; }
      .hm { background:var(--panel); padding:24px 18px; }
      .hm b { display:block; font-size:clamp(28px,4vw,40px); font-weight:700; }
      .hm b i { font-size:16px; font-style:normal; color:var(--orange); }
      .hm span { font-size:11px; letter-spacing:.1em; color:var(--mute); }
      @media (max-width:880px){ .hero-metrics { grid-template-columns:repeat(2,1fr); } }

      /* MARQUEE */
      .marquee { border-block:1px solid var(--line); overflow:hidden; background:var(--panel); }
      .marquee-track { display:flex; gap:40px; padding:14px 0; white-space:nowrap; width:max-content; animation:scroll 36s linear infinite; }
      .marquee-track span { color:var(--dim); font-size:12px; letter-spacing:.14em; text-transform:uppercase; }
      @keyframes scroll { to { transform:translateX(-50%); } }

      section { padding:11vh 6vw; }
      h2 { font-size:clamp(30px,4.6vw,58px); }
      .sec-head { display:flex; justify-content:space-between; align-items:flex-end; gap:40px; margin-bottom:52px; flex-wrap:wrap; }
      .sec-note { max-width:42ch; color:var(--mute); font-size:16px; font-weight:300; line-height:1.55; }

      /* MODES — telemetry cards */
      .mode-grid { display:grid; grid-template-columns:repeat(5,1fr); gap:12px; }
      .mode-card { background:var(--panel); border:1px solid var(--line); border-radius:18px; padding:22px 20px 24px; transition:border-color .2s, transform .2s; }
      .mode-card:hover { border-color:#3a3a40; transform:translateY(-3px); }
      .mode-top { display:flex; align-items:center; justify-content:space-between; margin-bottom:16px; }
      .mode-idx { color:var(--dim); font-size:12px; letter-spacing:.1em; }
      .mode-dot { width:11px; height:11px; border-radius:50%; background:hsl(calc(24 - var(--i)*4), 92%, calc(52% + var(--i)*7%)); box-shadow:0 0 14px 1px hsla(calc(24 - var(--i)*4), 92%, 55%, .7); }
      .mode-card h3 { font-size:30px; font-weight:700; }
      .mode-name { color:var(--orange); font-size:11px; letter-spacing:.14em; text-transform:uppercase; margin:5px 0 12px; }
      .mode-note { color:#9d978a; font-size:12.5px; line-height:1.5; min-height:56px; font-weight:300; }
      .tele { margin-top:16px; padding-top:16px; border-top:1px solid var(--line); display:flex; flex-direction:column; gap:11px; }
      .tele-row { display:flex; flex-direction:column; gap:5px; }
      .tele-row dt { color:var(--dim); font-size:9.5px; letter-spacing:.14em; }
      .tele-row dd { font-size:11px; color:var(--cream); }
      .tele-row dd.rival { color:var(--mute); }
      .meter { height:5px; border-radius:100px; background:#1e1e22; overflow:hidden; }
      .meter i { display:block; height:100%; width:var(--v); background:var(--grad); border-radius:100px; }
      @media (max-width:1080px){ .mode-grid { grid-template-columns:repeat(3,1fr); } }
      @media (max-width:880px){ .mode-grid { grid-template-columns:1fr; } .mode-note { min-height:0; } }

      /* FEATURE sections */
      .feature { display:grid; grid-template-columns:1fr 1fr; gap:56px; align-items:center; }
      .feature.reverse .feature-media { order:2; }
      .feature-media { position:relative; aspect-ratio:1/1; }
      .feature.reverse .feature-media { aspect-ratio:4/3; }
      .feature-media img { width:100%; height:100%; object-fit:cover; border-radius:18px; border:1px solid var(--line); }
      .label-tl { position:absolute; top:14px; left:14px; z-index:2; font-size:10px; letter-spacing:.12em; color:var(--amber); background:rgba(8,8,10,.62); border:1px solid var(--line); padding:5px 10px; border-radius:100px; backdrop-filter:blur(6px); }
      .feature-lede { margin-top:20px; color:#c6c1b5; font-size:17px; font-weight:300; line-height:1.55; max-width:44ch; }
      .ticks { list-style:none; margin:26px 0 0; display:flex; flex-direction:column; gap:16px; }
      .ticks li { font-size:15px; color:var(--mute); font-weight:300; padding-left:18px; border-left:2px solid; border-image:var(--grad) 1; line-height:1.5; }
      .ticks li strong { color:var(--cream); font-weight:600; }
      .datastrip { display:flex; gap:1px; margin-top:28px; background:var(--line); border:1px solid var(--line); border-radius:14px; overflow:hidden; }
      .datastrip div { background:var(--panel); padding:16px 18px; flex:1; }
      .datastrip span { display:block; font-size:10px; letter-spacing:.12em; color:var(--dim); margin-bottom:6px; }
      .datastrip b { font-size:15px; font-weight:600; }
      @media (max-width:880px){ .feature, .feature.reverse { grid-template-columns:1fr; gap:32px; } .feature.reverse .feature-media { order:0; } }

      /* VALUE bars */
      .bars { display:flex; flex-direction:column; gap:22px; max-width:960px; }
      .bar-row { display:grid; grid-template-columns:210px 1fr 62px; gap:20px; align-items:center; }
      .bar-fit { font-size:15px; font-weight:500; }
      .bar-stack { display:flex; flex-direction:column; gap:7px; }
      .bar-track { position:relative; height:32px; background:#151517; border:1px solid var(--line); border-radius:8px; overflow:hidden; }
      .bar { height:100%; border-radius:7px; }
      .bar.lava { background:var(--grad); }
      .bar.rival { background:#2c2a26; }
      .bar-tag { position:absolute; top:50%; left:12px; transform:translateY(-50%); font-size:11px; color:#160b04; font-weight:500; }
      .bar-tag.ghost-tag { color:var(--mute); }
      .bar-save { font-size:19px; font-weight:600; color:#7ee081; text-align:right; }
      @media (max-width:720px){ .bar-row { grid-template-columns:1fr 56px; } .bar-fit { grid-column:1 / -1; } }

      /* CONFIGURE */
      .configure { display:grid; grid-template-columns:1fr 1fr; gap:56px; align-items:center; background:var(--panel); border-block:1px solid var(--line); }
      .cfg-copy h2 { font-size:clamp(28px,4vw,50px); }
      .cfg-copy p { color:#c6c1b5; margin:18px 0 28px; font-size:17px; font-weight:300; line-height:1.55; max-width:40ch; }
      .cfg-img { position:relative; aspect-ratio:16/10; }
      .cfg-img img { width:100%; height:100%; object-fit:cover; border-radius:16px; border:1px solid var(--line); }
      @media (max-width:880px){ .configure { grid-template-columns:1fr; } }

      /* FOOTER */
      .foot { text-align:center; padding:9vh 6vw; border-top:1px solid var(--line); }
      .foot img { height:24px; margin:0 auto 16px; }
      .foot p { color:var(--dim); font-size:11px; letter-spacing:.08em; }
    </style>
  </body>
</html>
