---
import Layout from "../../layouts/Layout.astro";
import AddToCart from "../../components/AddToCart.tsx";
import { getPadBySlug } from "../../lib/products";

const { slug } = Astro.params;
const pad = slug ? await getPadBySlug(slug) : null;

if (!pad) {
  return new Response(null, { status: 404, statusText: "Not found" });
}

const priceLabel = pad.priceMax ? `${pad.priceFrom} – ${pad.priceMax}` : (pad.priceFrom ?? "—");
---

<Layout title={`${pad.name} — Brake Pads Co.`}>
  <div class="container section">
    <a href="/" class="back-link">← All pads</a>

    <div class="detail">
      <div class="detail-media">
        {pad.image ? (
          <img src={pad.image} alt={pad.name} />
        ) : (
          <span class="card-media-placeholder">Brake pad</span>
        )}
      </div>

      <div class="detail-info">
        <h1>{pad.name}</h1>
        <p class="detail-price">{priceLabel}</p>
        {pad.description && <p class="detail-desc">{pad.description}</p>}
        <AddToCart client:load pad={pad} />
      </div>
    </div>
  </div>
</Layout>
